#!/usr/bin/env python3
"""Resolve a logical WorkStack role using a deliberately small YAML subset."""

from __future__ import annotations

import argparse
import ast
import json
import re
import sys
from pathlib import Path
from typing import Any


TOP_LEVEL_KEYS = {
    "version",
    "max_parallel_slices",
    "roles",
    "harnesses",
    "workflows",
    "workflow_harnesses",
    "reviewer_specialties",
}
ROUTE_KEYS = {"harness", "model", "effort", "fallbacks"}
NAME_RE = re.compile(r"^[A-Za-z0-9_.+-]+$")
INTEGER_RE = re.compile(r"^-?(?:0|[1-9][0-9]*)$")


class RoutingError(Exception):
    pass


def strip_comment(text: str) -> str:
    quote = None
    escaped = False
    for index, char in enumerate(text):
        if escaped:
            escaped = False
            continue
        if quote == '"' and char == "\\":
            escaped = True
            continue
        if char in {"'", '"'}:
            if quote is None:
                quote = char
            elif quote == char:
                quote = None
        elif char == "#" and quote is None and (index == 0 or text[index - 1].isspace()):
            return text[:index].rstrip()
    if quote is not None:
        raise RoutingError("unsupported YAML feature: unterminated quoted scalar")
    return text.rstrip()


def parse_scalar(text: str, path: Path, line_number: int) -> Any:
    location = f"{path}:{line_number}"
    if not text:
        raise RoutingError(f"{location}: missing scalar value")
    if text.startswith(("&", "*", "!", "|", ">", "[", "{")) or text in {"---", "..."}:
        raise RoutingError(f"{location}: unsupported YAML feature")
    if text in {"null", "Null", "NULL", "~"}:
        raise RoutingError(f"{location}: unsupported YAML feature: null scalar")
    if text in {"true", "True", "TRUE"}:
        return True
    if text in {"false", "False", "FALSE"}:
        return False
    if INTEGER_RE.fullmatch(text):
        return int(text)
    if text[0] in {"'", '"'}:
        try:
            value = ast.literal_eval(text)
        except (SyntaxError, ValueError) as error:
            raise RoutingError(f"{location}: invalid quoted scalar") from error
        if not isinstance(value, str):
            raise RoutingError(f"{location}: scalar must be a string")
        return value
    if any(marker in text for marker in (" &", " *", " !", "{", "}", "[", "]")):
        raise RoutingError(f"{location}: unsupported YAML feature")
    if ": " in text or text.endswith(":"):
        raise RoutingError(f"{location}: quote scalar strings containing a colon")
    if re.fullmatch(r"[-+]?(?:\d+\.\d*|\d*\.\d+)(?:[eE][-+]?\d+)?", text):
        raise RoutingError(f"{location}: unsupported YAML feature: floating-point scalar")
    return text


def split_mapping_entry(content: str, path: Path, line_number: int) -> tuple[str, str]:
    if ":" not in content:
        raise RoutingError(f"{path}:{line_number}: expected a mapping entry")
    key, value = content.split(":", 1)
    key = key.strip()
    if key == "<<":
        raise RoutingError(f"{path}:{line_number}: unsupported YAML feature: merge key")
    if not NAME_RE.fullmatch(key):
        raise RoutingError(f"{path}:{line_number}: unsupported mapping key {key!r}")
    return key, value.strip()


def parse_yaml(path: Path) -> dict[str, Any]:
    try:
        raw_lines = path.read_text(encoding="utf-8").splitlines()
    except OSError as error:
        raise RoutingError(f"cannot read {path}: {error}") from error

    tokens: list[tuple[int, str, int]] = []
    for line_number, raw in enumerate(raw_lines, 1):
        if "\t" in raw[: len(raw) - len(raw.lstrip())]:
            raise RoutingError(f"{path}:{line_number}: tabs are not supported for indentation")
        content = strip_comment(raw.lstrip())
        if not content:
            continue
        indent = len(raw) - len(raw.lstrip(" "))
        if indent % 2:
            raise RoutingError(f"{path}:{line_number}: indentation must use two-space steps")
        if content in {"---", "..."}:
            raise RoutingError(f"{path}:{line_number}: unsupported YAML feature: document marker")
        tokens.append((indent, content, line_number))

    if not tokens:
        return {}
    if tokens[0][0] != 0:
        raise RoutingError(f"{path}:{tokens[0][2]}: top-level mapping must not be indented")

    def parse_mapping(index: int, indent: int) -> tuple[dict[str, Any], int]:
        result: dict[str, Any] = {}
        while index < len(tokens):
            current_indent, content, line_number = tokens[index]
            if current_indent < indent:
                break
            if current_indent > indent:
                raise RoutingError(f"{path}:{line_number}: unexpected indentation")
            if content.startswith("-"):
                break
            key, value_text = split_mapping_entry(content, path, line_number)
            if key in result:
                raise RoutingError(f"{path}:{line_number}: duplicate key {key!r}")
            index += 1
            if value_text:
                result[key] = parse_scalar(value_text, path, line_number)
                continue
            if index >= len(tokens) or tokens[index][0] <= indent:
                raise RoutingError(f"{path}:{line_number}: empty mappings are not supported")
            child_indent, child_content, _ = tokens[index]
            if child_indent != indent + 2:
                raise RoutingError(f"{path}:{tokens[index][2]}: indentation must use two-space steps")
            if child_content.startswith("-"):
                if key != "fallbacks":
                    raise RoutingError(f"{path}:{tokens[index][2]}: lists are supported only for fallbacks")
                result[key], index = parse_sequence(index, child_indent)
            else:
                result[key], index = parse_mapping(index, child_indent)
        return result, index

    def parse_sequence(index: int, indent: int) -> tuple[list[dict[str, Any]], int]:
        result: list[dict[str, Any]] = []
        while index < len(tokens):
            current_indent, content, line_number = tokens[index]
            if current_indent < indent:
                break
            if current_indent != indent or not content.startswith("- "):
                raise RoutingError(f"{path}:{line_number}: fallback entries must be mappings")
            key, value_text = split_mapping_entry(content[2:], path, line_number)
            if not value_text:
                raise RoutingError(f"{path}:{line_number}: fallback fields require scalar values")
            item = {key: parse_scalar(value_text, path, line_number)}
            index += 1
            while index < len(tokens) and tokens[index][0] > indent:
                child_indent, child_content, child_line = tokens[index]
                if child_indent != indent + 2 or child_content.startswith("-"):
                    raise RoutingError(f"{path}:{child_line}: invalid fallback indentation")
                child_key, child_value = split_mapping_entry(child_content, path, child_line)
                if not child_value:
                    raise RoutingError(f"{path}:{child_line}: fallback fields require scalar values")
                if child_key in item:
                    raise RoutingError(f"{path}:{child_line}: duplicate key {child_key!r}")
                item[child_key] = parse_scalar(child_value, path, child_line)
                index += 1
            result.append(item)
        return result, index

    parsed, final_index = parse_mapping(0, 0)
    if final_index != len(tokens):
        raise RoutingError(f"{path}:{tokens[final_index][2]}: unsupported YAML structure")
    return parsed


def require_mapping(value: Any, location: str) -> dict[str, Any]:
    if not isinstance(value, dict):
        raise RoutingError(f"{location} must be a mapping")
    return value


def validate_route(
    route: Any, location: str, allowed_efforts: set[str] | None = None
) -> dict[str, Any]:
    route = require_mapping(route, location)
    unknown = set(route) - ROUTE_KEYS
    if unknown:
        raise RoutingError(f"{location} has unsupported key {sorted(unknown)[0]!r}")
    for field in ("harness", "model", "effort"):
        value = route.get(field)
        if not isinstance(value, str) or not value.strip():
            raise RoutingError(f"{location}.{field} must be a non-empty string")
    if allowed_efforts is not None and route["effort"] not in allowed_efforts:
        choices = ", ".join(sorted(allowed_efforts))
        raise RoutingError(f"{location}.effort must be one of: {choices}")

    fallbacks = route.get("fallbacks", [])
    if not isinstance(fallbacks, list):
        raise RoutingError(f"{location}.fallbacks must be an ordered list")
    normalized_fallbacks = []
    for index, fallback in enumerate(fallbacks):
        normalized = validate_route(
            fallback, f"{location}.fallbacks[{index}]", allowed_efforts
        )
        if normalized["fallbacks"]:
            raise RoutingError(f"{location}.fallbacks[{index}] cannot contain fallbacks")
        normalized_fallbacks.append({key: normalized[key] for key in ("harness", "model", "effort")})
    return {
        "harness": route["harness"],
        "model": route["model"],
        "effort": route["effort"],
        "fallbacks": normalized_fallbacks,
    }


def validate_config(
    config: dict[str, Any], location: str, allowed_efforts: set[str] | None = None
) -> dict[str, Any]:
    unknown = set(config) - TOP_LEVEL_KEYS
    if unknown:
        raise RoutingError(f"{location} has unsupported top-level key {sorted(unknown)[0]!r}")
    if config.get("version", 1) != 1 or isinstance(config.get("version", 1), bool):
        raise RoutingError(f"{location}.version must be integer 1")
    maximum = config.get("max_parallel_slices")
    if maximum is not None and (isinstance(maximum, bool) or not isinstance(maximum, int) or maximum < 1):
        raise RoutingError(f"{location}.max_parallel_slices must be a positive integer")

    for section in ("roles", "harnesses", "workflows", "reviewer_specialties"):
        entries = require_mapping(config.get(section, {}), f"{location}.{section}")
        for name, route in entries.items():
            validate_route(route, f"{location}.{section}.{name}", allowed_efforts)
    workflow_harnesses = require_mapping(
        config.get("workflow_harnesses", {}), f"{location}.workflow_harnesses"
    )
    for workflow, harnesses in workflow_harnesses.items():
        harnesses = require_mapping(harnesses, f"{location}.workflow_harnesses.{workflow}")
        for harness, route in harnesses.items():
            validate_route(
                route,
                f"{location}.workflow_harnesses.{workflow}.{harness}",
                allowed_efforts,
            )
    return config


def collect_efforts(config: dict[str, Any]) -> set[str]:
    efforts: set[str] = set()

    def visit(value: Any) -> None:
        if isinstance(value, dict):
            if isinstance(value.get("effort"), str):
                efforts.add(value["effort"])
            for child in value.values():
                visit(child)
        elif isinstance(value, list):
            for child in value:
                visit(child)

    visit(config)
    return efforts


def get_route(config: dict[str, Any], *keys: str) -> dict[str, Any] | None:
    value: Any = config
    for key in keys:
        if not isinstance(value, dict) or key not in value:
            return None
        value = value[key]
    return validate_route(value, ".".join(keys))


def parse_override_fallback(value: str) -> dict[str, str]:
    fields = value.split(",")
    if len(fields) != 3 or any(not field for field in fields):
        raise argparse.ArgumentTypeError("fallback must be HARNESS,MODEL,EFFORT")
    return {key: item for key, item in zip(("harness", "model", "effort"), fields)}


def parse_args() -> argparse.Namespace:
    parser = argparse.ArgumentParser(description=__doc__)
    parser.add_argument("--project-root", type=Path, required=True)
    parser.add_argument("--role", required=True)
    parser.add_argument("--harness")
    parser.add_argument("--workflow")
    parser.add_argument("--reviewer-specialty")
    parser.add_argument("--author-model")
    parser.add_argument("--parallel-slices", type=int, default=1)
    parser.add_argument("--override-harness")
    parser.add_argument("--override-model")
    parser.add_argument("--override-effort")
    parser.add_argument(
        "--override-fallback", action="append", default=[], type=parse_override_fallback
    )
    return parser.parse_args()


def select_route(
    args: argparse.Namespace,
    bundled: dict[str, Any],
    project: dict[str, Any],
    allowed_efforts: set[str],
) -> tuple[dict[str, Any], str]:
    override_values = (args.override_harness, args.override_model, args.override_effort)
    if any(override_values) or args.override_fallback:
        if not all(override_values):
            raise RoutingError(
                "explicit override requires --override-harness, --override-model, and --override-effort"
            )
        return validate_route(
            {
                "harness": args.override_harness,
                "model": args.override_model,
                "effort": args.override_effort,
                "fallbacks": args.override_fallback,
            },
            "explicit override",
            allowed_efforts,
        ), "explicit"

    candidates: list[tuple[dict[str, Any] | None, str]] = []
    if args.role == "reviewer" and args.reviewer_specialty:
        candidates.extend(
            [
                (
                    get_route(project, "reviewer_specialties", args.reviewer_specialty),
                    "project:reviewer-specialty",
                ),
                (
                    get_route(bundled, "reviewer_specialties", args.reviewer_specialty),
                    "bundled:reviewer-specialty",
                ),
            ]
        )
    if args.workflow and args.harness:
        candidates.append(
            (
                get_route(project, "workflow_harnesses", args.workflow, args.harness),
                "project:workflow+harness",
            )
        )
    if args.workflow:
        candidates.append((get_route(project, "workflows", args.workflow), "project:workflow"))
    if args.harness:
        candidates.append((get_route(project, "harnesses", args.harness), "project:harness"))
    candidates.extend(
        [
            (get_route(project, "roles", args.role), "project:role"),
            (get_route(bundled, "roles", args.role), "bundled:role"),
        ]
    )
    for route, source in candidates:
        if route is not None:
            return route, source
    raise RoutingError(f"no route found for role {args.role!r}")


def enforce_reviewer_independence(
    role: str, route: dict[str, Any], source: str, author_model: str | None
) -> tuple[dict[str, Any], str, str | None]:
    if role != "reviewer":
        return route, source, None
    if not author_model:
        raise RoutingError("reviewer role requires --author-model")
    author_identity = author_model.strip().casefold()
    independent_fallbacks = [
        (index, fallback)
        for index, fallback in enumerate(route["fallbacks"])
        if fallback["model"].strip().casefold() != author_identity
    ]
    if route["model"].strip().casefold() != author_identity:
        return {
            **route,
            "fallbacks": [fallback for _, fallback in independent_fallbacks],
        }, source, None
    if not independent_fallbacks:
        raise RoutingError("no independent reviewer route is available")
    index, fallback = independent_fallbacks[0]
    selected = {
        **fallback,
        "fallbacks": [item for _, item in independent_fallbacks[1:]],
    }
    return (
        selected,
        f"{source}:fallback[{index}]",
        "reviewer model matches author model identity",
    )


def main() -> int:
    args = parse_args()
    if args.parallel_slices < 1:
        raise RoutingError("--parallel-slices must be a positive integer")
    if args.reviewer_specialty and args.role != "reviewer":
        raise RoutingError("--reviewer-specialty is valid only for the reviewer role")

    skill_root = Path(__file__).resolve().parent.parent
    bundled = validate_config(parse_yaml(skill_root / "defaults.yaml"), "bundled defaults")
    allowed_efforts = collect_efforts(bundled)
    if not allowed_efforts:
        raise RoutingError("bundled defaults define no effort levels")
    project_path = args.project_root / ".workstack" / "agents.yaml"
    project = (
        validate_config(parse_yaml(project_path), "project configuration", allowed_efforts)
        if project_path.exists()
        else {}
    )

    maximum = project.get("max_parallel_slices", bundled.get("max_parallel_slices"))
    if maximum is not None and args.parallel_slices > maximum:
        raise RoutingError(
            f"requested {args.parallel_slices} parallel slices exceeds configured maximum {maximum}"
        )

    route, source = select_route(args, bundled, project, allowed_efforts)
    route, source, fallback_reason = enforce_reviewer_independence(
        args.role, route, source, args.author_model
    )
    result = {
        "role": args.role,
        "harness": route["harness"],
        "model": route["model"],
        "effort": route["effort"],
        "fallbacks": route["fallbacks"],
        "source": source,
        "fallback_reason": fallback_reason,
    }
    print(json.dumps(result, separators=(",", ":")))
    return 0


if __name__ == "__main__":
    try:
        raise SystemExit(main())
    except RoutingError as error:
        print(f"resolve-agent: {error}", file=sys.stderr)
        raise SystemExit(2)
