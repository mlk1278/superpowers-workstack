#!/usr/bin/env python3
"""Resolve a logical WorkStack role from bundled and project JSON config."""

from __future__ import annotations

import argparse
import json
import sys
from pathlib import Path
from typing import Any


class RoutingError(Exception):
    pass


def read_config(path: Path, *, optional: bool = False) -> dict[str, Any]:
    if optional and not path.exists():
        return {}
    try:
        value = json.loads(path.read_text(encoding="utf-8"))
    except OSError as error:
        raise RoutingError(f"cannot read {path}: {error}") from error
    except json.JSONDecodeError as error:
        raise RoutingError(
            f"invalid JSON in {path} at line {error.lineno}, column {error.colno}"
        ) from error
    if not isinstance(value, dict):
        raise RoutingError(f"{path} must contain a JSON object")
    version = value.get("version", 1)
    if type(version) is not int or version != 1:
        raise RoutingError(f"{path} version must be integer 1")
    return value


def normalize_route(value: Any, location: str) -> dict[str, Any]:
    if not isinstance(value, dict):
        raise RoutingError(f"{location} must be an object")
    route: dict[str, Any] = {}
    for field in ("harness", "model", "effort"):
        item = value.get(field)
        if not isinstance(item, str) or not item.strip():
            raise RoutingError(f"{location}.{field} must be a non-empty string")
        route[field] = item
    fallbacks = value.get("fallbacks", [])
    if not isinstance(fallbacks, list):
        raise RoutingError(f"{location}.fallbacks must be an array")
    route["fallbacks"] = []
    for index, fallback in enumerate(fallbacks):
        item = normalize_route(fallback, f"{location}.fallbacks[{index}]")
        if item["fallbacks"]:
            raise RoutingError(f"{location}.fallbacks[{index}] cannot contain fallbacks")
        route["fallbacks"].append(
            {field: item[field] for field in ("harness", "model", "effort")}
        )
    return route


def configured_route(
    config: dict[str, Any], location: str, *keys: str
) -> dict[str, Any] | None:
    value: Any = config
    for key in keys:
        if not isinstance(value, dict) or key not in value:
            return None
        value = value[key]
    return normalize_route(value, location)


def parse_fallback(value: str) -> dict[str, str]:
    fields = value.split(",")
    if len(fields) != 3 or any(not field for field in fields):
        raise argparse.ArgumentTypeError("fallback must be HARNESS,MODEL,EFFORT")
    return dict(zip(("harness", "model", "effort"), fields))


def parse_args() -> argparse.Namespace:
    parser = argparse.ArgumentParser(description=__doc__)
    parser.add_argument("--project-root", type=Path, required=True)
    parser.add_argument("--role", required=True)
    parser.add_argument("--harness")
    parser.add_argument("--workflow")
    parser.add_argument("--reviewer-specialty")
    parser.add_argument("--author-model")
    parser.add_argument("--override-harness")
    parser.add_argument("--override-model")
    parser.add_argument("--override-effort")
    parser.add_argument("--override-fallback", action="append", default=[], type=parse_fallback)
    return parser.parse_args()


def select_route(
    args: argparse.Namespace, bundled: dict[str, Any], project: dict[str, Any]
) -> tuple[dict[str, Any], str]:
    override = (args.override_harness, args.override_model, args.override_effort)
    if any(override) or args.override_fallback:
        if not all(override):
            raise RoutingError(
                "explicit override requires --override-harness, --override-model, and --override-effort"
            )
        return normalize_route(
            {
                "harness": args.override_harness,
                "model": args.override_model,
                "effort": args.override_effort,
                "fallbacks": args.override_fallback,
            },
            "explicit override",
        ), "explicit"

    candidates: list[tuple[dict[str, Any] | None, str]] = []
    if args.role == "reviewer" and args.reviewer_specialty:
        candidates.append(
            (
                configured_route(
                    project,
                    "project.reviewer_specialties",
                    "reviewer_specialties",
                    args.reviewer_specialty,
                ),
                "project:reviewer-specialty",
            )
        )
    if args.workflow:
        candidates.append(
            (
                configured_route(
                    project,
                    "project.workflows",
                    "workflows",
                    args.workflow,
                    args.role,
                ),
                "project:workflow",
            )
        )
    if args.harness:
        candidates.append(
            (
                configured_route(
                    project,
                    "project.harnesses",
                    "harnesses",
                    args.harness,
                    args.role,
                ),
                "project:harness",
            )
        )
    candidates.extend(
        [
            (
                configured_route(project, "project.roles", "roles", args.role),
                "project:role",
            ),
            (
                configured_route(bundled, "bundled.roles", "roles", args.role),
                "bundled:role",
            ),
        ]
    )
    for route, source in candidates:
        if route is not None:
            return route, source
    raise RoutingError(f"no route found for role {args.role!r}")


def enforce_reviewer_independence(
    role: str, route: dict[str, Any], source: str, author_model: str | None
) -> tuple[dict[str, Any], str, str | None]:
    if role != "reviewer":
        return route, source, None
    if not author_model:
        raise RoutingError("reviewer role requires --author-model")

    author = author_model.strip().casefold()
    independent = [
        (index, fallback)
        for index, fallback in enumerate(route["fallbacks"])
        if fallback["model"].strip().casefold() != author
    ]
    if route["model"].strip().casefold() != author:
        return {**route, "fallbacks": [item for _, item in independent]}, source, None
    if not independent:
        raise RoutingError("no independent reviewer route is available")

    index, primary = independent[0]
    return (
        {**primary, "fallbacks": [item for _, item in independent[1:]]},
        f"{source}:fallback[{index}]",
        "reviewer model matches author model identity",
    )


def main() -> int:
    args = parse_args()
    if args.reviewer_specialty and args.role != "reviewer":
        raise RoutingError("--reviewer-specialty is valid only for the reviewer role")
    if not args.project_root.is_dir():
        raise RoutingError(f"project root is not a directory: {args.project_root}")

    skill_root = Path(__file__).resolve().parent.parent
    bundled = read_config(skill_root / "defaults.json")
    project = read_config(
        args.project_root / ".workstack" / "agents.json", optional=True
    )
    route, source = select_route(args, bundled, project)
    route, source, fallback_reason = enforce_reviewer_independence(
        args.role, route, source, args.author_model
    )
    print(
        json.dumps(
            {"role": args.role, **route, "source": source, "fallback_reason": fallback_reason},
            separators=(",", ":"),
        )
    )
    return 0


if __name__ == "__main__":
    try:
        raise SystemExit(main())
    except RoutingError as error:
        print(f"resolve-agent: {error}", file=sys.stderr)
        raise SystemExit(2)
